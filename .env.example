# ── PostgreSQL (Beget Cloud) ─────────────────────────────
# Соберите строку из данных, которые Beget показывает при создании БД:
# postgresql://ПОЛЬЗОВАТЕЛЬ:ПАРОЛЬ@ХОСТ:5432/ИМЯ_БД
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ── Публичный адрес сайта ────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://new.prokatkaterov.ru"

# ── Telegram ─────────────────────────────────────────────
# Токен бота — от @BotFather (/newbot). Отозвать/сменить: /revoke.
# chat_id — ГРУППЫ, а не личного чата: так смена менеджера не требует
# правки кода, достаточно добавить/убрать человека в группе.
# У групп id отрицательный, вида -5416776321.
# Как узнать: добавить бота в группу, отправить в ней /start, затем
# https://api.telegram.org/bot<ТОКЕН>/getUpdates → result[].message.chat.id
TELEGRAM_BOT_TOKEN=""

# Секрет вебхука: Telegram присылает его в заголовке
# X-Telegram-Bot-Api-Secret-Token, и мы сверяем. Адрес вебхука публичный —
# без секрета подтвердить чужую бронь смог бы любой, кто его угадает.
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Задаётся при регистрации вебхука (setWebhook, поле secret_token).
TELEGRAM_WEBHOOK_SECRET=""
TELEGRAM_ADMIN_CHAT_ID=""

# ── Доступ в админку (этап админки) ──────────────────────
ADMIN_EMAIL=""
ADMIN_PASSWORD_HASH=""
AUTH_SECRET=""
