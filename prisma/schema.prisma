// Prisma schema — Судоходная Компания «Дно»
// БД: PostgreSQL (Beget Cloud). Источник правды для сайта, бота и админки.
// Применение: npx prisma migrate deploy  (миграции)  /  npx prisma db seed  (наполнение)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Флот ───────────────────────────
model Boat {
  id        String   @id @default(uuid())
  slug      String   @unique // напр. "galeon-640" — для ссылок
  dir       String // папка с фото в /uploads/boats
  cover     String // имя файла обложки
  photos    String[] // имена файлов галереи
  nameRu    String
  nameEn    String
  descRu    String
  descEn    String
  price     Int? // ₽/час; null = «по запросу»
  specs     Json? // { ru: [длина, ширина, высота, скорость, вместимость], en: [...] }
  amenities Json // { ru: [...], en: [...] }
  badge     Json? // { ru: "Бомбочка!", en: "Bombshell!" } — кричащий ярлык
  premium   Boolean  @default(false) // флагман: сдержанная золотая корона вместо ярлыка
  isNew     Boolean  @default(false)
  isVisible Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  bookings Booking[]

  @@index([isVisible, sortOrder])
}

// ─────────────────────────── Заявки ───────────────────────────
enum BookingStatus {
  NEW // Новая
  REVIEW // На рассмотрении
  CONFIRMED // Подтверждена
  COMPLETED // Завершена
  CANCELLED // Отменена
}

enum BookingSource {
  ORGANIC // Органический поиск (Google/Яндекс)
  ADS // Реклама (Яндекс.Директ/Google Ads)
  SOCIAL // Соцсети (VK/Telegram)
  REPEAT // Повторный клиент
  MANUAL // Добавлен администратором вручную
  UNKNOWN // Источник не определён
}

model Booking {
  id            String        @id @default(uuid())
  createdAt     DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime      @updatedAt @db.Timestamptz(3)
  boat          Boat          @relation(fields: [boatId], references: [id])
  boatId        String
  // timestamptz, а не timestamp: на этих полях строится exclusion-констрейнт
  // (tstzrange требует таймзону), и заявки приходят из разных поясов.
  startAt       DateTime      @db.Timestamptz(3) // начало прогулки
  endAt         DateTime      @db.Timestamptz(3) // конец; обязателен — на нём держится проверка пересечений
  guests        Int           @default(1)
  clientName    String
  phone         String
  telegram      String?
  comment       String?
  priceSnapshot Int? // стоимость на момент заявки — не переписывается
  status        BookingStatus @default(NEW)
  source        BookingSource @default(UNKNOWN)
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  lang          String        @default("ru")
  // id сообщения в группе Telegram — чтобы редактировать его же при смене
  // статуса, а не слать новое. null = уведомление не ушло (Telegram не
  // настроен или был недоступен).
  tgMessageId   Int?

  client        Client?                 @relation(fields: [clientId], references: [id])
  clientId      String?
  statusHistory BookingStatusHistory[]

  @@index([status, createdAt])
  @@index([boatId, startAt])
  @@index([source])
}

model BookingStatusHistory {
  id        String         @id @default(uuid())
  booking   Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId String
  from      BookingStatus?
  to        BookingStatus
  changedBy String? // кто сменил (админ)
  changedAt DateTime       @default(now()) @db.Timestamptz(3)

  @@index([bookingId])
}

// ─────────────────── Диалог создания брони в боте ───────────────────
// Менеджер заполняет карточку по шагам, а Telegram не хранит состояние между
// сообщениями. Держим черновик в БД, а не в памяти процесса: при перезапуске
// PM2 память обнулилась бы, и менеджер потерял бы наполовину введённую бронь.
model BotDraft {
  /** Чат, где идёт диалог: у менеджера может быть только один черновик разом. */
  chatId    String   @id
  userId    String
  step      String // boat | date | time | duration | name | phone | guests | comment
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([updatedAt])
}

// ──────────────── Диалог брони в клиентском боте ────────────────
// Отдельно от BotDraft намеренно: тот принадлежит менеджерскому боту с его
// шагами (mode/retime), этот — публичному клиентскому. Свести их в одну
// таблицу значило бы связать два разных продукта через общий тип черновика.
// Состояние в БД, а не в памяти — по той же причине, что и у BotDraft: при
// перезапуске PM2 наполовину введённая заявка не должна пропадать.
model ClientBotDraft {
  /** Личный чат клиента: у одного клиента один черновик разом. */
  chatId    String   @id
  step      String // day | hour | minute | duration | guests | name | phone | comment
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([updatedAt])
}

// ─────────────────────────── Админы ───────────────────────────
// Своя авторизация вместо Supabase Auth из ТЗ: в проекте нет Supabase, а нужен
// ровно один провайдер «email + пароль». Пароль хранится как scrypt-хеш
// (см. lib/auth.ts), сама сессия — в подписанной куке, без таблицы сессий:
// админов двое, инвалидация сессий не требуется.
model Admin {
  id           String    @id @default(uuid())
  email        String    @unique
  /** scrypt: соль и хеш в одной строке, разбор — в lib/auth.ts. */
  passwordHash String
  name         String
  /** Задел на роли: сейчас все админы равны, различать некого. */
  role         String    @default("admin")
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime? @db.Timestamptz(3)
  createdAt    DateTime  @default(now()) @db.Timestamptz(3)
}

// ─────────────────────────── Клиенты ───────────────────────────
model Client {
  id        String    @id @default(uuid())
  phone     String    @unique
  name      String?
  telegram  String?
  firstSeen DateTime  @default(now()) @db.Timestamptz(3)
  bookings  Booking[]
}

// ─────────────────────── Галерея «Моменты» ───────────────────────
// Фото и видео для раздела «Моменты» на главной. Файлы лежат на сервере в
// public/uploads/gallery (вне git — деплой их не трогает: он делает только
// `git checkout -- .` и `git pull`, без `git clean`). В базе — только имена
// файлов, как и у лодок.
model GalleryItem {
  id        String   @id @default(uuid())
  kind      String // 'image' | 'video'
  file      String   @unique // имя файла в public/uploads/gallery
  sortOrder Int      @default(0)
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  @@index([isVisible, sortOrder])
}
